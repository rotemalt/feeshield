# FeeShield Environment Variables Configuration
# Copy this file to '.env' in the same folder and fill in your keys

# Google Gemini API Key (Required for live statement audits & script generation)
# Get your key from Google AI Studio: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_actual_gemini_api_key_here

# Supabase Configuration (Optional - falls back to simulated localStorage if left blank)
# VITE_SUPABASE_URL=https://your-project-id.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Live Backend Parser URL (Optional - only if running a separate Python parser backend)
# VITE_BACKEND_URL=http://localhost:8000
